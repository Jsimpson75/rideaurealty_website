# Realtor.ca API via RapidAPI (https://rapidapi.com)
# Copy this file to .env and fill in your key. Do not commit .env.
# If a key was ever committed to git, rotate it in the RapidAPI dashboard.

VITE_RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: API host (default: realty-in-ca1.p.rapidapi.com)
# VITE_RAPIDAPI_HOST=realty-in-ca1.p.rapidapi.com
